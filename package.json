{
  "name": "beusable-design-system",
  "private": true,
  "version": "0.0.0",
  "description": "Beusable Design System Monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "build:tokens": "pnpm --filter @beusable-dev/tokens build",
    "dev": "pnpm -r dev",
    "storybook": "pnpm --filter @beusable-dev/storybook dev",
    "build:storybook": "pnpm --filter @beusable-dev/storybook build",
    "test": "pnpm -r --if-present test",
    "test:watch": "pnpm -r --parallel --if-present test:watch",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "pnpm -r --if-present lint",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "eslint": "^9.9.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
